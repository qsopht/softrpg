PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/softrpg

# Redis
REDIS_URL=redis://127.0.0.1:6379

# AI Provider - set to "openai" or "anthropic"
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE_URL=your_azure_openai_base_url_here
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Session
SESSION_SECRET=change_this_to_a_long_random_secret
